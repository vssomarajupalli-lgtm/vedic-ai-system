      "content_blocks": [
        {
          "type": "heading",
          "text": "బుధుడు మహాదశ 29.05.2027 నుంచి ప్రారంభం",
          "bbox": [
            19.5,
            9.822868347167969,
            330.61444091796875,
            52.02705383300781
