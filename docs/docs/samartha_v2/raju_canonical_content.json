      "content_blocks": [
        {
          "type": "heading",
          "text": "శని మహాదశలో చంద్రుడు భుక్తి 02.05.2019 నుంచి ప్రారంభం",
          "bbox": [
            19.5,
            9.666618347167969,
            405.2320251464844,
            52.03096008300781
